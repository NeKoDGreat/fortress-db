# ============================================================
# Fortress DB — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control — it is in .gitignore.
# ============================================================

# ── Data-at-Rest: Encryption Key ────────────────────────────
# Option A: Provide a pre-generated Fernet key (preferred for production)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# Option B: Derive key from password + salt (simpler, less secure)
DB_ENCRYPTION_PASSWORD=change-this-to-a-long-random-secret
DB_ENCRYPTION_SALT=change-this-to-16-hex-chars

# ── Database Path ────────────────────────────────────────────
# SQLite (development/demo):
DB_PATH=fortress.db

# PostgreSQL (production) — use sslmode=verify-full for Data-in-Transit
# DB_URL=postgresql://user:password@localhost:5432/fortress?sslmode=verify-full&sslrootcert=/path/to/ca.crt

# ── TLS / SSL Certificate ────────────────────────────────────
# Path to the database server's CA certificate (for verify-full)
DB_SSL_CERT=certs/server.crt

# ── Flask ────────────────────────────────────────────────────
FLASK_DEBUG=false
PORT=5000

# ── Secret Key (Flask sessions) ─────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-secret
