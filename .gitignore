__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-log.txt

# ── Virtual Environments ─────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ── Testing / Coverage ───────────────────────────────────────
